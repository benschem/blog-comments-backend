# Which environment to boot - picks the database block in config/database.yml
RACK_ENV=development

# Public base URL of this backend. Used to build the moderation links in the
# notification email (#{APP_BASE_URL}/moderate/<token>), so it must be reachable
# from wherever you open that email
APP_BASE_URL=http://localhost:9292 # Dev default - use the real host in prod

# Resend API key (secret, set in your real .env) - looks like re_xxx
RESEND_API_KEY=

# Verified Resend sender for moderation notifications
RESEND_FROM_EMAIL=comments@benschem.dev

# Inbox that receives the "new comment awaiting moderation" emails
MODERATION_NOTIFY_EMAIL=you@example.com

# Netlify build hook fired on approval so the site rebuilds and bakes in the comment
NETLIFY_BUILD_HOOK_URL=https://api.netlify.com/build_hooks/your_hook_id

# Credentials for the nightly database backups to R2 (production only)
# Read lazily only when a backup runs, so can safely leave blank in dev/test
# In production use a bucket-scoped, WRITE-ONLY R2 token (PutObject only)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
